# Rust TCP proxy target.
# Launch the release binary built via `cargo build --release` inside rust/.
# Env var names are identical to the PHP proxy so the Rust binary can parse them.

PROXY_ROOT_ENV="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

export TCP_BACKEND_ENDPOINT=127.0.0.1:15432
export TCP_POSTGRES_PORT=25432
export TCP_MYSQL_PORT=0
export TCP_SKIP_VALIDATION=1
export TCP_WORKERS=4

export BACKEND_TCP_PORT=15432

if [[ -n "${PROXY_HOST:-}" ]]; then
    BIN="${PROXY_REMOTE_DIR:-/opt/utopia-proxy}/rust/target/release/proxy tcp"
else
    BIN="${PROXY_ROOT_ENV}/rust/target/release/proxy tcp"
fi
