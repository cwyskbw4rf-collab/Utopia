# Rust HTTP proxy target.

PROXY_ROOT_ENV="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

export HTTP_BACKEND_ENDPOINT=127.0.0.1:5678
export HTTP_PORT=18080
export HTTP_SKIP_VALIDATION=1
export HTTP_WORKERS=4

export BACKEND_HTTP_PORT=5678

if [[ -n "${PROXY_HOST:-}" ]]; then
    BIN="${PROXY_REMOTE_DIR:-/opt/utopia-proxy}/rust/target/release/proxy http"
else
    BIN="${PROXY_ROOT_ENV}/rust/target/release/proxy http"
fi
